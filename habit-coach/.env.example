# Copie para .env (que é ignorado pelo git) OU, de preferência, configure
# estes valores como secrets/variáveis de ambiente da rotina em
# claude.ai/code/routines. Nunca faça commit do token.

# Token do BotFather (formato 123456:ABC-def...)
TELEGRAM_BOT_TOKEN=

# Opcional: chat id fixo. Se não definir, é detectado automaticamente a
# partir da última mensagem que você enviou ao bot.
TELEGRAM_CHAT_ID=
